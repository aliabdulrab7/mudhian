generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== المستخدمون والفروع ====================

model Branch {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  branchNum String        @default("")
  createdAt DateTime      @default(now())
  users     User[]
  drawers   DailyDrawer[]
  employees Employee[]

  // ERP relations
  jewelryItems  JewelryItem[]
  sales         Sale[]
  repairs       Repair[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  diamonds      DiamondStone[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("branch") // "admin" | "branch" | "viewer"
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())

  // ERP relations
  metalPrices MetalPrice[]
  sales       Sale[]
}

// ==================== اليومية ====================

model DailyDrawer {
  id       Int      @id @default(autoincrement())
  branchId Int
  branch   Branch   @relation(fields: [branchId], references: [id])
  date     DateTime

  // إجمالي قيمة المبيعات اليومية (يدوي)
  totalSales   Float @default(0)
  // قيمة الموازنة (يدوي = مبيعات البنك/الشبكة)
  balanceValue Float @default(0)

  // الإضافات (+)
  yesterdayBalance   Float @default(0) // يضاف رصيد أمس
  earnestReceived    Float @default(0) // يضاف عرابين مستلمة
  staffDeposits      Float @default(0) // مستلم أمانات سابقة لدى الموظفين / إضافات أخرى
  customerDepositsIn Float @default(0) // مستلم أمانات سابقة لدى الزبائن

  // الخصومات (-)
  adminWithdrawals    Float @default(0) // يخصم مسحوبات أبوسلطان
  previousEarnest     Float @default(0) // يخصم عرابين سابقة
  boxesBags           Float @default(0) // يخصم مشتريات علب وأكياس
  cashPurchases       Float @default(0) // يخصم مشتريات بضاعة كاش
  storeExpenses       Float @default(0) // يخصم مصروفات محل
  customerDepositsOut Float @default(0) // يخصم أمانات لدى الزبائن أو المحلات
  returns             Float @default(0) // يخصم المرتجع والمستبدل من الزبائن
  salariesAdvances    Float @default(0) // رواتب وسلف وخصومات أخرى

  // الرصيد الفعلي (يدخله الموظف)
  actualBalance Float @default(0)

  // صافي رصيد الدرج الدفتري (مخزّن للرجوع إليه في اليوم التالي)
  bookBalance Float @default(0)

  notes        String  @default("[]")   // JSON array of note strings
  fieldNotes   String  @default("{}")   // JSON: { fieldKey: "ملاحظة" }
  customFields String  @default("{}")   // JSON: { rowKey: value } for template custom rows
  isLocked     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  soldItems     SoldItem[]
  bankTransfers BankTransfer[]
  invoices      Invoice[]

  @@unique([branchId, date])
}

// الأصناف المباعة (6 أصناف ثابتة)
model SoldItem {
  id       Int         @id @default(autoincrement())
  drawerId Int
  drawer   DailyDrawer @relation(fields: [drawerId], references: [id], onDelete: Cascade)
  category String      // طقم، خاتم، حلق، اسوارة، تعليقة، نص طقم
  quantity Int         @default(0)
}

// سجل التغييرات
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  username  String
  action    String
  details   String   @default("")
  createdAt DateTime @default(now())
}

// إعدادات النظام (admin-controlled global settings)
model AppSetting {
  key   String @id
  value String @default("")
}

// الفواتير المباعة (يدوي، مرجعية فقط)
model Invoice {
  id           Int         @id @default(autoincrement())
  drawerId     Int
  drawer       DailyDrawer @relation(fields: [drawerId], references: [id], onDelete: Cascade)
  type         String      // "صميت" | "عادية"
  invoiceNum   String      @default("")
  price        Float       @default(0)
  employeeName String      @default("")
  employeeId   Int?
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  barcodes     String      @default("[]") // JSON array of barcode strings
  createdAt    DateTime    @default(now())
}

// الموظفون
model Employee {
  id        Int       @id @default(autoincrement())
  branchId  Int
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  invoices  Invoice[]
  sales     Sale[]
  repairs   Repair[]
}

// الحوالات البنكية (5 بنوك ثابتة)
model BankTransfer {
  id          Int         @id @default(autoincrement())
  drawerId    Int
  drawer      DailyDrawer @relation(fields: [drawerId], references: [id], onDelete: Cascade)
  bankName    String      // الانماء، الراجحي، الرياض، ساب، الاهلي
  amount      Float       @default(0)
  beneficiary String      @default("")
  notes       String      @default("")
}

// ==================== نظام ERP للمجوهرات ====================

// المخزون — قطع المجوهرات
model JewelryItem {
  id            Int      @id @default(autoincrement())
  sku           String   @unique           // رمز القطعة (توليد تلقائي مثل RNG-0001)
  barcode       String   @unique           // باركود للطابعة
  category      String                     // خاتم | سواره | عقد | حلق | طقم | صيانة | أخرى
  metalType     String   @default("gold")  // gold | silver | platinum
  karat         Int      @default(18)      // عيار: 18 | 21 | 22 | 24
  grossWeight   Float    @default(0)       // الوزن الإجمالي (جرام)
  netWeight     Float    @default(0)       // الوزن الصافي للمعدن (جرام)
  stoneType     String   @default("")      // نوع الحجر (الماس، ياقوت، زمرد ...)
  stoneWeight   Float    @default(0)       // وزن الحجر (قيراط)
  stoneCount    Int      @default(0)       // عدد الأحجار
  stoneValue    Float    @default(0)       // قيمة الحجر (ريال)
  makingCharges Float    @default(0)       // أجرة الصنعة (ريال)
  cost          Float    @default(0)       // سعر التكلفة (ريال)
  salePrice     Float    @default(0)       // سعر البيع (ريال) — يُحسب تلقائياً
  margin        Float    @default(0)       // هامش الربح (ريال)
  status        String   @default("available") // available | sold | reserved | repair
  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id])
  supplierId    Int?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  supplierRef   String   @default("")      // مرجع المورد (نص حر - للتوافق مع البيانات القديمة)
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  soldAt        DateTime?

  saleItems     SaleItem[]
  transferItems StockTransferItem[]

  @@index([branchId])
  @@index([status])
  @@index([category])
}

// أسعار المعادن اليومية (يدوي من الإدارة)
model MetalPrice {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  metalType    String   @default("gold")  // gold | silver | platinum
  pricePerGram Float                       // سعر الجرام بالريال
  setBy        Int
  user         User     @relation(fields: [setBy], references: [id])
  createdAt    DateTime @default(now())

  @@unique([date, metalType])
  @@index([date])
}

// العملاء
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @default("")
  vatNumber String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())

  sales   Sale[]
  repairs Repair[]
}

// المبيعات (فاتورة بيع)
model Sale {
  id            Int       @id @default(autoincrement())
  invoiceNum    String    @unique           // رقم الفاتورة (توليد تلقائي)
  branchId      Int
  branch        Branch    @relation(fields: [branchId], references: [id])
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  employeeId    Int?
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  totalAmount   Float     @default(0)
  discountAmount Float    @default(0)
  paymentMethod String    @default("cash") // cash | card | transfer
  notes         String    @default("")
  createdAt     DateTime  @default(now())
  createdBy     Int
  user          User      @relation(fields: [createdBy], references: [id])

  saleItems SaleItem[]

  @@index([branchId])
  @@index([createdAt])
}

// بنود فاتورة البيع
model SaleItem {
  id            Int         @id @default(autoincrement())
  saleId        Int
  sale          Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  jewelryItemId Int
  jewelryItem   JewelryItem @relation(fields: [jewelryItemId], references: [id])
  price         Float       // لقطة من سعر البيع وقت البيع
  discount      Float       @default(0)
  costAtSale    Float       @default(0) // تكلفة القطعة وقت البيع (للمحاسبة)
}

// الصيانة والإصلاح
model Repair {
  id             Int       @id @default(autoincrement())
  branchId       Int
  branch         Branch    @relation(fields: [branchId], references: [id])
  customerId     Int?
  customer       Customer? @relation(fields: [customerId], references: [id])
  employeeId     Int?
  employee       Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  itemDescription String              // وصف القطعة المُصلَحة
  receivedCondition String @default("") // حالة القطعة عند الاستلام
  estimatedCost  Float     @default(0)  // تكلفة الإصلاح المتوقعة
  actualCost     Float     @default(0)  // التكلفة الفعلية
  status         String    @default("received") // received | in_progress | completed | delivered
  receivedAt     DateTime  @default(now())
  estimatedReady DateTime?
  deliveredAt    DateTime?
  notes          String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  statusLogs RepairStatusLog[]

  @@index([branchId])
  @@index([status])
}

// سجل حالات الصيانة
model RepairStatusLog {
  id        Int      @id @default(autoincrement())
  repairId  Int
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
  status    String   // received | in_progress | completed | delivered
  note      String   @default("")
  changedBy Int      // userId
  changedAt DateTime @default(now())

  @@index([repairId])
}

// ==================== الموردون ====================

model Supplier {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  phone        String        @default("")
  email        String        @default("")
  address      String        @default("")
  notes        String        @default("")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  jewelryItems JewelryItem[]
  diamonds     DiamondStone[]
}

// ==================== تحويلات المخزون ====================

model StockTransfer {
  id           Int                 @id @default(autoincrement())
  fromBranchId Int
  fromBranch   Branch              @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId   Int
  toBranch     Branch              @relation("TransferTo", fields: [toBranchId], references: [id])
  status       String              @default("pending") // pending | completed | cancelled
  notes        String              @default("")
  createdBy    Int
  createdAt    DateTime            @default(now())
  completedAt  DateTime?
  items        StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
}

model StockTransferItem {
  id            Int           @id @default(autoincrement())
  transferId    Int
  transfer      StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  jewelryItemId Int
  jewelryItem   JewelryItem   @relation(fields: [jewelryItemId], references: [id])
}

// ==================== المحاسبة المزدوجة (Double-Entry GL) ====================

// دليل الحسابات
model Account {
  id         Int           @id @default(autoincrement())
  code       String        @unique       // e.g. "1011"
  nameAr     String                      // الاسم بالعربي
  nameEn     String        @default("")  // English name
  type       String                      // asset | liability | equity | revenue | expense
  parentCode String        @default("")  // كود الحساب الأب
  isActive   Boolean       @default(true)
  notes      String        @default("")
  createdAt  DateTime      @default(now())

  journalLines JournalLine[]

  @@index([type])
  @@index([parentCode])
}

// قيود اليومية
model JournalEntry {
  id          Int           @id @default(autoincrement())
  entryNum    String        @unique          // JE-YYYYMMDD-NNNN
  date        DateTime      @db.Date
  description String        @default("")
  ref         String        @default("")     // رقم الفاتورة أو مرجع القيد
  type        String        @default("manual") // manual | sale | refund | purchase | payroll
  status      String        @default("posted") // draft | posted | void
  branchId    Int?
  postedBy    Int                              // userId
  createdAt   DateTime      @default(now())

  lines JournalLine[]

  @@index([date])
  @@index([ref])
  @@index([type])
  @@index([branchId])
}

// بنود القيد
model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Float        @default(0)
  credit      Float        @default(0)
  description String       @default("")
  branchId    Int?

  @@index([entryId])
  @@index([accountId])
}

// ==================== الألماس ====================

model DiamondStone {
  id             Int       @id @default(autoincrement())
  sku            String    @unique
  caratWeight    Float     @default(0)
  color          String    @default("")   // D, E, F, G, H, I, J, K, L, M, N
  clarity        String    @default("")   // FL, IF, VVS1, VVS2, VS1, VS2, SI1, SI2, I1, I2, I3
  cut            String    @default("")   // Excellent, Very Good, Good, Fair, Poor
  shape          String    @default("Round")
  certificateNum String    @default("")
  certBody       String    @default("")   // GIA, IGI, HRD, AGS
  origin         String    @default("")
  cost           Float     @default(0)
  salePrice      Float     @default(0)
  status         String    @default("available") // available | sold | mounted
  branchId       Int
  branch         Branch    @relation(fields: [branchId], references: [id])
  supplierId     Int?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  notes          String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([branchId])
  @@index([status])
}
